<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_surface"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="New Count"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Task Name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="COUNT NAME  ✱ required"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etTaskName"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. Push-ups, Dog walks…"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:inputType="textCapWords"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Daily Goal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DAILY GOAL  (optional)"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etDailyGoal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. 50"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:inputType="number"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Weekly Goal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WEEKLY GOAL  (optional)"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etWeeklyGoal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. 300"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:inputType="number"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Monthly Goal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MONTHLY GOAL  (optional)"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etMonthlyGoal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. 1200"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:inputType="number"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="16dp"/>

    <!-- Yearly Goal -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="YEARLY GOAL  (optional)"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etYearlyGoal"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="e.g. 15000"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:inputType="number"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="24dp"/>


    <!-- Reminder section -->
    <include layout="@layout/view_reminder_section"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnDialogCancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CANCEL"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/btn_dialog_cancel"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnDialogSave"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CREATE"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:background="@drawable/btn_dialog_save"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>
