<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_surface"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Edit Past Entry"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvEditHistoryTask"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/accent_blue"
        android:textSize="13sp"
        android:layout_marginBottom="20dp"/>

    <!-- Date label -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DATE"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <!-- Date selector row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/btnPrevDay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="◀"
            android:textColor="@color/accent_blue"
            android:textSize="16sp"
            android:background="@drawable/btn_dialog_cancel"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/tvSelectedDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnNextDay"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="▶"
            android:textColor="@color/accent_blue"
            android:textSize="16sp"
            android:background="@drawable/btn_dialog_cancel"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Current total for selected day -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/input_bg"
        android:padding="14dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Current total for this day"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvCurrentDayTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/accent_blue"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- New total input -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SET NEW TOTAL FOR THIS DAY"
        android:textColor="@color/accent_blue"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:layout_marginBottom="6dp"/>

    <EditText
        android:id="@+id/etNewTotal"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Enter corrected total"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted"
        android:textSize="18sp"
        android:inputType="number"
        android:gravity="center"
        android:background="@drawable/input_bg"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="A corrective entry will be added to match this total. Original entries are preserved."
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:lineSpacingMultiplier="1.3"
        android:layout_marginBottom="24dp"/>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnDialogCancel"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="CANCEL"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_dialog_cancel"
            android:layout_marginEnd="8dp"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:id="@+id/btnDialogSave"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="SAVE"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/btn_dialog_save"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
